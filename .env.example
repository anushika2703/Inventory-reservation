# Database (Supabase/Neon/Railway Postgres)
# For Vercel deployment, use the pooled connection string
DATABASE_URL="postgresql://postgres.PROJECT:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Redis (Upstash or other provider)
REDIS_URL="rediss://default:password@host.upstash.io:6379"

# Optional: For Vercel Cron authentication
CRON_SECRET="your-random-secret-here"
